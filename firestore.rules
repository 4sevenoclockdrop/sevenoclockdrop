rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /entries/{entryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /pot/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /freeClaims/{username} {
      allow read, write: if request.auth != null;
    }
    match /winners/{winnerId} {
      allow read: if true;
    }
  }
}